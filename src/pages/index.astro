---
// src/pages/index.astro
import SiteLayout from "../layouts/SiteLayout.astro";
import Hero from "../components/Hero.astro";
import VillaCard from "../components/VillaCard.astro";
import SisterProperties from "../components/SisterProperties.astro";
import { Image } from "astro:assets";
import { getCollection } from "astro:content";
import { site } from "../data/site";

import imgHeroBg from "../assets/images/1-.jpg-and-use-for-home-page-too-under-villas-feel-right-.-1-1568x1045-1.jpg";
import imgInterior from "../assets/images/DSC09431-1024x683.jpg";
import imgBalcony from "../assets/images/DSC09464-300x200.jpg";
import imgStateBeach from "../assets/images/Beachwalk-Villas-Beachside.png";
import imgVillage from "../assets/images/carlsbad-sign-pic.jpg";
import imgFlower from "../assets/images/activities-img-04.jpg";
import imgLego from "../assets/images/activities-img-02.jpg";
import imgContactBg from "../assets/images/DSC09464-2048x1365.jpg";

const allVillas = await getCollection("villas");
const featuredVillas = allVillas
  .filter((v) => v.data.featured)
  .sort((a, b) => a.data.sortOrder - b.data.sortOrder)
  .slice(0, 3);

const amenities = [
  { label: "Steps to the Shore", icon: "wave" },
  { label: "Sparkling Pool", icon: "pool" },
  { label: "Fully Equipped Kitchens", icon: "kitchen" },
  { label: "Free Parking", icon: "car" },
  { label: "Fast Wi-Fi", icon: "wifi" },
  { label: "Near Downtown Carlsbad", icon: "pin" },
];

const attractions = [
  {
    name: "Carlsbad State Beach",
    distance: "Steps away",
    image: imgStateBeach,
  },
  {
    name: "Carlsbad Village",
    distance: "5 min",
    image: imgVillage,
  },
  {
    name: "The Flower Fields",
    distance: "8 min",
    image: imgFlower,
  },
  {
    name: "LEGOLAND California",
    distance: "10 min",
    image: imgLego,
  },
];
---

<SiteLayout
  title="Oceanfront Vacation Villas in Carlsbad, CA"
  description="Beachwalk Villas — contemporary oceanfront vacation rentals in Carlsbad, California, steps from the shore and near Downtown Carlsbad. Welcome to our beachfront escape."
>
  <!-- Hero -->
  <Hero
    eyebrow="Carlsbad, California"
    headline="Welcome To Our Beachfront Escape"
    subheadline="Contemporary, elegantly decorated villas steps from the shore — feel right at home on the Southern California coast."
    ctaLabel="Explore Villas"
    ctaHref="/villas/"
    ctaSecondaryLabel="Book Now"
    ctaSecondaryHref="/contact-us/"
    bgImage={imgHeroBg}
    size="full"
  />

  <!-- Welcome / Feel right at home -->
  <section class="section-pad bg-sand reveal">
    <div class="container-site">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">
        <div>
          <span class="eyebrow">Welcome to Beachwalk Villas</span>
          <h2 class="section-heading mb-5">Feel right at home, right on the coast</h2>
          <p class="text-brand-muted leading-relaxed mb-5">
            Tucked along the Carlsbad shoreline and just minutes from Downtown
            Carlsbad, Beachwalk Villas is a collection of contemporary,
            residential-style retreats — from sunny poolside studios to
            unobstructed oceanfront escapes.
          </p>
          <p class="text-brand-muted leading-relaxed mb-8">
            Every villa is thoughtfully decorated and fully equipped, so you can
            slip off your shoes, open the balcony doors, and let the sound of the
            Pacific do the rest.
          </p>
          <div class="flex flex-col sm:flex-row gap-4">
            <a href="/villas/" class="btn btn-primary">Explore Villas</a>
            <a href="/contact-us/" class="btn btn-outline">Book Now</a>
          </div>
        </div>

        <div class="grid grid-cols-2 gap-4">
          <Image
            src={imgInterior}
            alt="Sun-washed Beachwalk Villas interior"
            width={600}
            class="rounded-card w-full aspect-[3/4] object-cover shadow-[var(--shadow-soft)]"
            loading="lazy"
          />
          <Image
            src={imgBalcony}
            alt="Oceanfront balcony view"
            width={600}
            class="rounded-card w-full aspect-[3/4] object-cover shadow-[var(--shadow-soft)] mt-8"
            loading="lazy"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Amenities strip -->
  <section class="bg-seafoam text-white reveal">
    <div class="container-site py-12 md:py-14">
      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-y-8 gap-x-4">
        {
          amenities.map((a) => (
            <div class="flex flex-col items-center text-center gap-3">
              <span class="flex items-center justify-center w-12 h-12 rounded-full bg-white/12">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="1.6" viewBox="0 0 24 24" aria-hidden="true">
                  {a.icon === "wave" && (
                    <path stroke-linecap="round" stroke-linejoin="round" d="M2 13c2 0 2-1.5 4-1.5S8 13 10 13s2-1.5 4-1.5S16 13 18 13s2-1.5 4-1.5M2 18c2 0 2-1.5 4-1.5S8 18 10 18s2-1.5 4-1.5S16 18 18 18s2-1.5 4-1.5" />
                  )}
                  {a.icon === "pool" && (
                    <path stroke-linecap="round" stroke-linejoin="round" d="M3 18c1.5 0 1.5-1 3-1s1.5 1 3 1 1.5-1 3-1 1.5 1 3 1 1.5-1 3-1M7 16V6a2 2 0 1 1 4 0M13 16V6a2 2 0 1 1 4 0M7 9h4m2 0h4" />
                  )}
                  {a.icon === "kitchen" && (
                    <path stroke-linecap="round" stroke-linejoin="round" d="M5 3v8m0 0a2 2 0 0 0 2-2V3M5 11v10M19 3c-1.5 0-3 2-3 5s1 4 3 4m0 0v9" />
                  )}
                  {a.icon === "car" && (
                    <path stroke-linecap="round" stroke-linejoin="round" d="M4 16v3m16-3v3M5 16l1.5-5A2 2 0 0 1 8.4 9.7h7.2a2 2 0 0 1 1.9 1.3L19 16M5 16h14M7 13h2m6 0h2M5 16a1.5 1.5 0 1 0 0 .01M19 16a1.5 1.5 0 1 0 0 .01" />
                  )}
                  {a.icon === "wifi" && (
                    <path stroke-linecap="round" stroke-linejoin="round" d="M2.5 9a14 14 0 0 1 19 0M6 12.5a9 9 0 0 1 12 0M9.5 16a4 4 0 0 1 5 0M12 19.5h.01" />
                  )}
                  {a.icon === "pin" && (
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 21s7-5.5 7-11a7 7 0 1 0-14 0c0 5.5 7 11 7 11Zm0-8.5a2.5 2.5 0 1 0 0-5 2.5 2.5 0 0 0 0 5Z" />
                  )}
                </svg>
              </span>
              <span class="text-sm font-medium text-white/90">{a.label}</span>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Featured villas -->
  <section class="section-pad bg-sand reveal">
    <div class="container-site">
      <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-5 mb-12">
        <div>
          <span class="eyebrow">Our Villas</span>
          <h2 class="section-heading">Featured stays by the sea</h2>
        </div>
        <a href="/villas/" class="btn btn-outline self-start md:self-auto">View all 10 villas</a>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-7">
        {
          featuredVillas.map((villa) => (
            <VillaCard
              name={villa.data.name}
              id={villa.id}
              category={villa.data.category}
              viewType={villa.data.viewType}
              image={villa.data.image}
              specs={villa.data.specs}
              tagline={villa.data.tagline}
            />
          ))
        }
      </div>
    </div>
  </section>

  <!-- Carlsbad attractions teaser -->
  <section class="section-pad bg-brand-surface reveal">
    <div class="container-site">
      <div class="text-center max-w-2xl mx-auto mb-12">
        <span class="eyebrow">Explore Carlsbad</span>
        <h2 class="section-heading mx-auto">A coastal town with everything close by</h2>
        <p class="section-subheading mx-auto mt-3">
          Wide sandy beaches, the charm of Carlsbad Village, world-famous
          flower fields, and family favorites — all just minutes from your door.
        </p>
      </div>

      <div class="grid grid-cols-2 lg:grid-cols-4 gap-5">
        {
          attractions.map((a) => (
            <a href="/attractions/" class="group relative block overflow-hidden rounded-card aspect-[3/4] shadow-[var(--shadow-soft)]">
              <Image
                src={a.image}
                alt={a.name}
                width={400}
                class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
                loading="lazy"
              />
              <div class="absolute inset-0 scrim" />
              <div class="absolute bottom-0 left-0 right-0 p-5 text-white">
                <span class="badge badge-coral mb-2">{a.distance}</span>
                <h3 class="font-serif text-lg leading-tight">{a.name}</h3>
              </div>
            </a>
          ))
        }
      </div>

      <div class="text-center mt-10">
        <a href="/attractions/" class="btn btn-outline">See all attractions</a>
      </div>
    </div>
  </section>

  <!-- Sister properties -->
  <SisterProperties />

  <!-- Contact band with phone number -->
  <section class="relative overflow-hidden reveal">
    <Image
      src={imgContactBg}
      alt=""
      width={1920}
      class="absolute inset-0 w-full h-full object-cover"
      loading="lazy"
    />
    <div class="absolute inset-0 bg-navy/72"></div>
    <div class="relative container-site py-20 md:py-28 text-center text-white">
      <span class="eyebrow !text-terracotta">Ready when you are</span>
      <h2 class="font-serif text-h1 mb-4 mt-2">Reserve your beachfront escape</h2>
      <p class="text-white/85 text-lg max-w-xl mx-auto mb-8">
        Check availability, ask a question, or book your stay. We'd love to help
        you plan the perfect Carlsbad getaway.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
        <a href="/contact-us/" class="btn btn-coral">Book Now</a>
        <a href={site.phoneHref} class="btn btn-white">
          Call {site.phone}
        </a>
      </div>
    </div>
  </section>
</SiteLayout>
