---
// src/pages/404.astro
import SiteLayout from '../layouts/SiteLayout.astro';
---

<SiteLayout title="Page Not Found">
  <section class="min-h-[60vh] flex items-center justify-center bg-brand-sand">
    <div class="text-center px-4">
      <p class="font-display text-8xl text-brand-teal mb-4">404</p>
      <h1 class="font-display text-h1 text-brand-navy mb-4">Page Not Found</h1>
      <p class="text-gray-600 max-w-md mx-auto mb-8">
        The page you're looking for doesn't exist or may have moved.
        Let's get you back to the beach.
      </p>
      <div class="flex gap-4 justify-center">
        <a href="/" class="btn-primary">Go Home</a>
        <a href="/villas/" class="btn-outline">View Villas</a>
      </div>
    </div>
  </section>
</SiteLayout>
