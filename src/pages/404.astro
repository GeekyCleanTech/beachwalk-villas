---
// src/pages/404.astro
import SiteLayout from '../layouts/SiteLayout.astro';
---

<SiteLayout title="Page Not Found">
  <section class="min-h-[64vh] flex items-center justify-center bg-brand-sand">
    <div class="text-center px-4">
      <p class="font-display text-8xl text-brand-coral mb-4">404</p>
      <h1 class="font-display text-h1 text-brand-navy mb-4">Page not found</h1>
      <p class="text-brand-muted max-w-md mx-auto mb-8">
        The page you're looking for doesn't exist or may have moved.
        Let's get you back to the beach.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/" class="btn btn-primary">Go home</a>
        <a href="/villas/" class="btn btn-outline">View villas</a>
      </div>
    </div>
  </section>
</SiteLayout>
