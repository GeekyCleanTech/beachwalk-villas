---
// src/pages/amenities.astro
import SiteLayout from "../layouts/SiteLayout.astro";
import Hero from "../components/Hero.astro";

const amenityGroups = [
  {
    category: "Beach & Outdoors",
    items: [
      "Steps to the Pacific Ocean",
      "Community Pool",
      "Sun Deck",
      "BBQ Area",
      "Outdoor Shower",
      "Beach Access",
    ],
  },
  {
    category: "Villa Features",
    items: [
      "Full Kitchen",
      "Living Room",
      "Dining Area",
      "Private Patio or Balcony",
      "In-Unit Washer/Dryer",
      "Air Conditioning",
    ],
  },
  {
    category: "Kitchen & Dining",
    items: [
      "Refrigerator",
      "Stove & Oven",
      "Microwave",
      "Dishwasher",
      "Coffee Maker",
      "Full Cookware & Utensils",
    ],
  },
  {
    category: "Entertainment",
    items: [
      "Smart TV",
      "High-Speed WiFi",
      "Streaming Services",
      "Bluetooth Speaker",
    ],
  },
  {
    category: "Comfort & Linens",
    items: [
      "Premium Bedding",
      "Fresh Towels",
      "Beach Towels",
      "Iron & Ironing Board",
      "Hair Dryer",
    ],
  },
  {
    category: "Parking & Access",
    items: ["Free Parking", "Keyless Entry", "24/7 Check-In", "Self Check-Out"],
  },
];
---

<SiteLayout
  title="Amenities"
  description="Discover the full range of amenities at Beachwalk Villas in Carlsbad, CA — pool, beach access, full kitchens, parking, and more."
>
  <Hero
    eyebrow="Comfort, fully equipped"
    headline="Amenities"
    subheadline="Everything you need for the perfect coastal getaway."
    bgImage="/images/amenities-banner.jpg"
    size="medium"
  />

  <section class="section-pad bg-sand reveal">
    <div class="container-site">
      <!-- Intro -->
      <div class="max-w-2xl mb-12">
        <span class="eyebrow">Resort-style living</span>
        <h2 class="section-heading">Designed for easy coastal living</h2>
        <p class="section-subheading mt-3">
          Beachwalk Villas is designed for comfort, convenience, and coastal
          living. Every villa comes fully equipped so you can relax from the
          moment you arrive.
        </p>
      </div>

      <!-- Feature photos -->
      <div class="grid grid-cols-2 md:grid-cols-3 gap-4 mb-16">
        {
          [
            { src: "/images/amenities-banner.jpg", alt: "Beachwalk amenities" },
            { src: "/images/amenities-box-img1.jpg", alt: "Pool area" },
            { src: "/images/amenities-box-img2-1.jpg", alt: "Villa interior" },
          ].map((img) => (
            <div class="aspect-[4/3] overflow-hidden rounded-card shadow-[var(--shadow-soft)]">
              <img
                src={img.src}
                alt={img.alt}
                class="w-full h-full object-cover"
                loading="lazy"
              />
            </div>
          ))
        }
      </div>

      <!-- Amenity groups grid -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {
          amenityGroups.map((group) => (
            <div class="card p-7">
              <h3 class="font-serif text-xl text-navy mb-4">
                {group.category}
              </h3>
              <ul class="space-y-2.5">
                {group.items.map((item) => (
                  <li class="flex items-start gap-2.5 text-sm text-brand-muted">
                    <svg
                      class="w-4 h-4 text-seafoam mt-0.5 flex-shrink-0"
                      fill="currentColor"
                      viewBox="0 0 20 20"
                    >
                      <path
                        fill-rule="evenodd"
                        d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"
                        clip-rule="evenodd"
                      />
                    </svg>
                    {item}
                  </li>
                ))}
              </ul>
            </div>
          ))
        }
      </div>

      <div class="mt-12 text-center">
        <a href="/villas/" class="btn btn-primary">View our villas</a>
      </div>
    </div>
  </section>
</SiteLayout>
