---
// src/pages/health-and-safety.astro
import SiteLayout from '../layouts/SiteLayout.astro';
import Hero from '../components/Hero.astro';
---

<SiteLayout
  title="Health & Safety"
  description="Beachwalk Villas health and safety guidelines for guests — cleaning protocols, check-in procedures, and property safety information."
>
  <Hero
    headline="Health & Safety"
    subheadline="Your safety and comfort are our highest priority."
    bgImage="/images/health.jpg"
    size="medium"
    ctaLabel={undefined}
  />

  <section class="section-pad bg-white">
    <div class="container-site max-w-3xl">
      <div class="prose prose-lg max-w-none">

        <h2 class="font-display text-h2 text-brand-navy">Our Commitment to Your Safety</h2>
        <p class="text-gray-600">
          At Beachwalk Villas, we are committed to providing a safe, clean, and comfortable environment
          for all of our guests. We follow enhanced cleaning and safety protocols to ensure your stay
          exceeds expectations.
        </p>

        <h3 class="font-display text-h3 text-brand-navy mt-8">Enhanced Cleaning Protocols</h3>
        <ul class="space-y-2 text-gray-600">
          <li>All villas are thoroughly cleaned and sanitized between each guest stay</li>
          <li>High-touch surfaces are disinfected with hospital-grade cleaning products</li>
          <li>All linens and towels are washed at high temperature</li>
          <li>A 24-hour buffer is observed between guest check-out and the next check-in</li>
        </ul>

        <h3 class="font-display text-h3 text-brand-navy mt-8">Contactless Check-In & Check-Out</h3>
        <ul class="space-y-2 text-gray-600">
          <li>Keyless entry on all villas — no key exchange required</li>
          <li>Check-in instructions sent electronically prior to arrival</li>
          <li>24/7 self check-in available</li>
          <li>Self check-out — no contact needed on departure</li>
        </ul>

        <h3 class="font-display text-h3 text-brand-navy mt-8">Pool & Common Areas</h3>
        <ul class="space-y-2 text-gray-600">
          <li>Common areas are regularly cleaned and sanitized</li>
          <li>Pool area and deck furniture are cleaned daily</li>
          <li>Hand sanitizer stations available throughout the property</li>
        </ul>

        <h3 class="font-display text-h3 text-brand-navy mt-8">Emergency Information</h3>
        <ul class="space-y-2 text-gray-600">
          <li>Emergency contact information is posted in each villa</li>
          <li>First aid kits are available in each unit</li>
          <li>Fire extinguishers and smoke detectors in all villas</li>
          <li>Nearest hospital: Tri-City Medical Center — 15 minutes from property</li>
        </ul>

        <div class="bg-brand-sand p-6 mt-10">
          <h3 class="font-display text-xl text-brand-navy mb-2">Questions?</h3>
          <p class="text-gray-600 text-sm mb-4">
            If you have any health or safety questions before or during your stay, please don't hesitate to contact us.
          </p>
          <a href="/contact-us/" class="btn-primary">Contact Us</a>
        </div>

      </div>
    </div>
  </section>
</SiteLayout>
