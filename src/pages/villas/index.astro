---
// src/pages/villas/index.astro
import SiteLayout from '../../layouts/SiteLayout.astro';
import Hero from '../../components/Hero.astro';
import VillaCard from '../../components/VillaCard.astro';
import { getCollection } from 'astro:content';

const allVillas = await getCollection('villas');
const villas = allVillas.sort((a, b) => a.data.sortOrder - b.data.sortOrder);

// Group by type for filtering
const types = ['ocean-front', 'ocean-view', 'avenue-view', 'garden-view', 'poolside-studio'];
const typeLabels: Record<string, string> = {
  'ocean-front':     'Ocean Front',
  'ocean-view':      'Ocean View',
  'avenue-view':     'Avenue View',
  'garden-view':     'Garden View',
  'poolside-studio': 'Poolside Studio',
};
---

<SiteLayout
  title="Our Villas"
  description="Browse all 10 vacation villas at Beachwalk Villas in Carlsbad, CA — oceanfront, ocean view, avenue view, garden view, and poolside studios."
>
  <Hero
    headline="Our Villas"
    subheadline="Ten unique villas. One stunning Carlsbad location."
    bgImage="/images/beachwalk-featured-images.jpg"
    size="medium"
    ctaLabel={undefined}
  />

  <!-- Filter bar -->
  <div class="bg-white border-b border-gray-100 sticky top-16 md:top-20 z-40">
    <div class="container-site py-3 flex flex-wrap gap-2">
      <button
        class="villa-filter-btn active px-4 py-1.5 text-sm font-semibold border border-brand-teal bg-brand-teal text-white transition-colors"
        data-filter="all"
      >
        All Villas ({villas.length})
      </button>
      {types.map(type => {
        const count = villas.filter(v => v.data.type === type).length;
        return count > 0 ? (
          <button
            class="villa-filter-btn px-4 py-1.5 text-sm font-semibold border border-gray-200 text-gray-600 hover:border-brand-teal hover:text-brand-teal transition-colors"
            data-filter={type}
          >
            {typeLabels[type]} ({count})
          </button>
        ) : null;
      })}
    </div>
  </div>

  <!-- Villas grid -->
  <section class="section-pad bg-brand-sand">
    <div class="container-site">
      <div id="villas-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {villas.map(villa => (
          <div class="villa-item" data-type={villa.data.type}>
            <VillaCard
              title={villa.data.title}
              slug={villa.data.slug}
              type={villa.data.type}
              thumbnailImage={villa.data.thumbnailImage}
              bedrooms={villa.data.bedrooms}
              bathrooms={villa.data.bathrooms}
              unitAmenities={villa.data.unitAmenities}
              nightlyRate={villa.data.nightlyRate}
            />
          </div>
        ))}
      </div>
    </div>
  </section>
</SiteLayout>

<script>
  const filterBtns = document.querySelectorAll('.villa-filter-btn');
  const villaItems = document.querySelectorAll('.villa-item');

  filterBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      const filter = btn.getAttribute('data-filter');

      // Update active button
      filterBtns.forEach(b => {
        b.classList.remove('active', 'bg-brand-teal', 'text-white', 'border-brand-teal');
        b.classList.add('border-gray-200', 'text-gray-600');
      });
      btn.classList.add('active', 'bg-brand-teal', 'text-white', 'border-brand-teal');
      btn.classList.remove('border-gray-200', 'text-gray-600');

      // Show/hide villas
      villaItems.forEach(item => {
        const type = item.getAttribute('data-type');
        if (filter === 'all' || type === filter) {
          (item as HTMLElement).style.display = '';
        } else {
          (item as HTMLElement).style.display = 'none';
        }
      });
    });
  });
</script>
