---
import VillaLayout from "../../layouts/VillaLayout.astro";
import GalleryIsland from "../../components/GalleryIsland";
import ContactForm from "../../components/ContactForm.astro";
import { getCollection, render } from "astro:content";
import type { GetStaticPaths } from "astro";
import { site } from "../../data/site";

export const getStaticPaths = (async () => {
  const villas = await getCollection("villas");
  return villas.map((villa) => ({
    params: { slug: villa.id },
    props: { villa },
  }));
}) satisfies GetStaticPaths;

const { villa } = Astro.props;
const { Content } = await render(villa);

const {
  name: title,
  category,
  viewType,
  image: thumbnailImageObj,
  galleryImages: galleryImagesObjs,
  specs: { bedrooms, bathrooms, maxGuests, sqft },
  layout,
  tagline,
  unitAmenities,
  metaDescription,
} = villa.data;

const typeLabel = `${viewType} ${category}`;

const thumbnailImage = thumbnailImageObj?.src || '';
const galleryImages = galleryImagesObjs?.map(img => img.src) || [];

const allImages = [
  thumbnailImage,
  ...galleryImages.filter((img) => img !== thumbnailImage),
];

const facts: { label: string; value: string }[] = [
  { label: "Type", value: typeLabel },
  { label: "Bedrooms", value: bedrooms === 0 ? "Studio" : String(bedrooms) },
  { label: "Bathrooms", value: String(bathrooms) },
];
if (maxGuests) facts.push({ label: "Sleeps", value: `${maxGuests} guests` });
if (sqft) facts.push({ label: "Size", value: `${sqft.toLocaleString()} sq ft` });
if (layout) facts.push({ label: "Layout", value: layout });

const chips = [
  bedrooms === 0 ? "Studio" : `${bedrooms} bed`,
  `${bathrooms} bath`,
  ...(maxGuests ? [`${maxGuests} guests`] : []),
  ...(sqft ? [`${sqft.toLocaleString()} sq ft`] : []),
];

// Structured data for this specific rental unit + breadcrumb trail
const siteUrl = "https://beachwalkvillas.net";
const villaUrl = `${siteUrl}/villas/${villa.id}/`;
const accommodationLd = {
  "@context": "https://schema.org",
  "@type": "Accommodation",
  name: title,
  description: tagline ?? metaDescription,
  url: villaUrl,
  image: allImages.map((img) => `${siteUrl}${img}`),
  numberOfBedrooms: bedrooms,
  numberOfBathroomsTotal: bathrooms,
  ...(maxGuests
    ? { occupancy: { "@type": "QuantitativeValue", maxValue: maxGuests, unitText: "guests" } }
    : {}),
  ...(sqft
    ? { floorSize: { "@type": "QuantitativeValue", value: sqft, unitCode: "FTK" } }
    : {}),
  amenityFeature: unitAmenities.map((a) => ({
    "@type": "LocationFeatureSpecification",
    name: a,
    value: true,
  })),
  containedInPlace: { "@type": "LodgingBusiness", name: site.name, url: siteUrl },
};
const breadcrumbLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home", item: `${siteUrl}/` },
    { "@type": "ListItem", position: 2, name: "Villas", item: `${siteUrl}/villas/` },
    { "@type": "ListItem", position: 3, name: title, item: villaUrl },
  ],
};
---

<VillaLayout
  title={title}
  description={metaDescription}
  image={thumbnailImage}
  jsonLd={[accommodationLd, breadcrumbLd]}
>
  <!-- Breadcrumb -->
  <div class="bg-sand border-b border-brand-border">
    <div class="container-site py-3 text-sm text-brand-muted">
      <a href="/" class="hover:text-seafoam">Home</a>
      <span class="mx-2">/</span>
      <a href="/villas/" class="hover:text-seafoam">Villas</a>
      <span class="mx-2">/</span>
      <span class="text-navy font-medium">{title}</span>
    </div>
  </div>

  <section class="section-pad bg-sand reveal !pt-12">
    <div class="container-site">
      <!-- Title block -->
      <div class="mb-8 max-w-3xl">
        <span class="eyebrow">{typeLabel}</span>
        <h1 class="font-serif text-h1 mt-2 mb-3">{title}</h1>
        {tagline && <p class="text-lg text-brand-muted">{tagline}</p>}
        <div class="flex flex-wrap gap-2 mt-5">
          {chips.map((c) => <span class="chip">{c}</span>)}
        </div>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-3 gap-10 lg:gap-12">
        <!-- Gallery + body -->
        <div class="lg:col-span-2">
          <GalleryIsland client:load images={allImages} title={title} />

          <div class="prose-coastal mt-10">
            <Content />
          </div>

          {
            unitAmenities.length > 0 && (
              <div class="mt-10 pt-8 border-t border-brand-border">
                <h2 class="font-serif text-h3 mb-5">Villa Features</h2>
                <ul class="grid grid-cols-1 sm:grid-cols-2 gap-x-8 gap-y-3">
                  {unitAmenities.map((a) => {
                    const match = a.match(/^\*\*(.*?)\*\*(.*)/);
                    let bold = match ? match[1].trim() : '';
                    let rest = match ? match[2].trim() : a;
                    if (bold.endsWith(':')) {
                      bold = bold.slice(0, -1).trim();
                    }
                    if (rest.startsWith(':')) {
                      rest = rest.slice(1).trim();
                    }
                    return (
                      <li class="flex items-start gap-3 text-navy">
                        <span class="flex items-center justify-center w-7 h-7 rounded-full bg-seafoam/10 flex-shrink-0 mt-0.5">
                          <svg class="w-4 h-4 text-seafoam" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                            <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                          </svg>
                        </span>
                        <span class="text-sm">
                          {bold ? <strong class="font-semibold">{bold}:</strong> : ''}
                          {rest}
                        </span>
                      </li>
                    );
                  })}
                </ul>
              </div>
            )
          }
        </div>

        <!-- Sticky inquiry sidebar -->
        <aside class="lg:col-span-1">
          <div class="lg:sticky lg:top-28 space-y-5">
            <div class="card p-7">
              <h2 class="font-serif text-h3 mb-1">Plan your stay</h2>
              <p class="text-sm text-brand-muted mb-5">{typeLabel} · {site.location}</p>

              <dl class="space-y-3 text-sm border-t border-brand-border pt-5">
                {
                  facts.map((f) => (
                    <div class="flex justify-between gap-4">
                      <dt class="text-brand-muted">{f.label}</dt>
                      <dd class="font-semibold text-navy text-right">{f.value}</dd>
                    </div>
                  ))
                }
              </dl>

              <a href="#inquire" class="btn btn-coral w-full mt-6">Book Now</a>
              <a href={site.phoneHref} class="btn btn-outline w-full mt-3">
                Call {site.phone}
              </a>
            </div>

            <div class="card p-7">
              <h3 class="font-serif text-lg mb-3">Good to know</h3>
              <ul class="space-y-2.5 text-sm">
                <li><a href="/amenities/" class="text-seafoam hover:underline">Property amenities</a></li>
                <li><a href="/reservation-policies/" class="text-seafoam hover:underline">Reservation &amp; booking policies</a></li>
                <li><a href="/attractions/" class="text-seafoam hover:underline">Things to do in Carlsbad</a></li>
              </ul>
            </div>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <!-- Inquiry -->
  <section id="inquire" class="section-pad bg-brand-surface reveal scroll-mt-24">
    <div class="container-site max-w-2xl">
      <div class="text-center mb-8">
        <span class="eyebrow">Make it yours</span>
        <h2 class="section-heading mx-auto">Inquire about {title}</h2>
      </div>
      <ContactForm title={`Inquire about ${title}`} preselectVilla={title} />
    </div>
  </section>

  <div class="bg-sand border-t border-brand-border py-6">
    <div class="container-site">
      <a href="/villas/" class="text-seafoam font-semibold hover:underline text-sm">
        ← Back to all villas
      </a>
    </div>
  </div>
</VillaLayout>
