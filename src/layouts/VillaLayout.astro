---
// src/layouts/VillaLayout.astro
import SiteLayout from './SiteLayout.astro';

interface Props {
  title: string;
  description?: string;
  image?: string;
  jsonLd?: object | object[];
}

const { title, description, image, jsonLd } = Astro.props;
---

<SiteLayout title={title} description={description} image={image} jsonLd={jsonLd}>
  <slot />
</SiteLayout>
