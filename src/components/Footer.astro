---
// src/components/Footer.astro
import { site, navLinks, footerLinks, sisterProperties } from "../data/site";
const year = new Date().getFullYear();
---

<footer class="bg-brand-navy text-white/80">
  <div class="container-site py-16 md:py-20">
    <div class="grid grid-cols-1 md:grid-cols-12 gap-10 md:gap-8">
      <!-- Brand -->
      <div class="md:col-span-4">
        <img
          src="/images/footer-logo.png"
          alt="Beachwalk Villas"
          class="h-12 w-auto mb-5"
          loading="lazy"
        />
        <p class="text-sm leading-relaxed text-white/70 max-w-xs mb-5">
          Oceanfront vacation villas in Carlsbad, California — steps from the
          shore and near Downtown Carlsbad. Feel right at home.
        </p>
        <a
          href={site.phoneHref}
          class="font-display text-2xl text-white hover:text-brand-coral transition-colors"
        >
          {site.phone}
        </a>
      </div>

      <!-- Explore -->
      <div class="md:col-span-3">
        <h3 class="font-display text-lg text-white mb-4">Explore</h3>
        <ul class="space-y-2.5 text-sm">
          {
            [...navLinks.slice(1), ...footerLinks].map((link) => (
              <li>
                <a
                  href={link.href}
                  class="text-white/70 hover:text-white transition-colors"
                >
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <!-- Other properties -->
      <div class="md:col-span-3">
        <h3 class="font-display text-lg text-white mb-4">Other Properties</h3>
        <ul class="space-y-2.5 text-sm">
          {
            sisterProperties.map((p) => (
              <li>
                <a
                  href={p.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-white/70 hover:text-white transition-colors"
                >
                  {p.name}
                </a>
              </li>
            ))
          }
          <li>
            <a
              href="/#other-properties"
              class="text-brand-coral hover:text-white transition-colors font-medium"
            >
              View all →
            </a>
          </li>
        </ul>
      </div>

      <!-- Contact -->
      <div class="md:col-span-2">
        <h3 class="font-display text-lg text-white mb-4">Contact</h3>
        <address class="not-italic text-sm space-y-2.5 text-white/70">
          <p>{site.location}</p>
          <p>
            <a href={site.emailHref} class="hover:text-white transition-colors">
              {site.email}
            </a>
          </p>
          <p>
            <a href={site.phoneHref} class="hover:text-white transition-colors">
              {site.phone}
            </a>
          </p>
        </address>
      </div>
    </div>

    <!-- Bottom bar -->
    <div
      class="mt-12 pt-6 border-t border-white/10 flex flex-col sm:flex-row items-center justify-between gap-3 text-xs text-white/50"
    >
      <p>&copy; {year} {site.name}. All rights reserved.</p>
      <a href="/reservation-policies/" class="hover:text-white/80 transition-colors">
        Booking Policies
      </a>
    </div>
  </div>
</footer>
