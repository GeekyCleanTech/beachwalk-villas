---
// src/components/Footer.astro
const year = new Date().getFullYear();
---

<footer class="bg-brand-navy text-gray-300">
  <div class="container-site py-12 md:py-16">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-10">

      <!-- Brand column -->
      <div>
        <a href="/">
          <img
            src="/images/footer-logo.png"
            alt="Beachwalk Villas"
            class="h-12 w-auto mb-4"
            loading="lazy"
          />
        </a>
        <p class="text-sm leading-relaxed text-gray-400 max-w-xs">
          Luxury vacation villas in Carlsbad, California — steps from the Pacific Ocean.
        </p>
      </div>

      <!-- Quick links -->
      <div>
        <h3 class="text-white font-display text-lg mb-4">Quick Links</h3>
        <ul class="space-y-2 text-sm">
          {[
            ['Villas',            '/villas/'],
            ['Amenities',        '/amenities/'],
            ['Attractions',      '/attractions/'],
            ['Promotions',       '/promotions/'],
            ['Booking Policies', '/reservation-policies/'],
            ['Health & Safety',  '/health-and-safety/'],
            ['Contact Us',       '/contact-us/'],
          ].map(([label, href]) => (
            <li>
              <a href={href} class="hover:text-white transition-colors duration-150">{label}</a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact info -->
      <div>
        <h3 class="text-white font-display text-lg mb-4">Contact</h3>
        <address class="not-italic text-sm space-y-2 text-gray-400">
          <p>Beachwalk Villas</p>
          <p>Carlsbad, CA</p>
          <p>
            <a href="mailto:info@beachwalkvillas.net" class="hover:text-white transition-colors">
              info@beachwalkvillas.net
            </a>
          </p>
        </address>
      </div>

    </div>

    <!-- Bottom bar -->
    <div class="mt-10 pt-6 border-t border-white/10 flex flex-col sm:flex-row items-center justify-between gap-3 text-xs text-gray-500">
      <p>&copy; {year} Beachwalk Villas. All rights reserved.</p>
      <a href="/privacy-policy/" class="hover:text-gray-300 transition-colors">Privacy Policy</a>
    </div>
  </div>
</footer>
