---
// src/components/SisterProperties.astro
import { sisterProperties } from "../data/site";
---

<section id="other-properties" class="section-pad bg-brand-sand reveal scroll-mt-24">
  <div class="container-site">
    <div class="text-center max-w-2xl mx-auto mb-12">
      <span class="eyebrow">Our Family of Properties</span>
      <h2 class="section-heading mx-auto">Other Places to Stay</h2>
      <p class="section-subheading mx-auto mt-3">
        Beachwalk Villas is part of a small family of distinctive Southern
        California stays. Explore our sister properties for your next getaway.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {
        sisterProperties.map((p) => (
          <a
            href={p.url}
            target="_blank"
            rel="noopener noreferrer"
            class="card group p-8 text-center flex flex-col items-center transition-shadow duration-300 hover:shadow-[var(--shadow-lift)]"
          >
            <span class="eyebrow mb-3">Sister Property</span>
            <h3 class="font-display text-h3 mb-3 transition-colors group-hover:text-brand-teal">
              {p.name}
            </h3>
            <p class="text-sm text-brand-muted leading-relaxed">{p.blurb}</p>
            <span class="mt-5 inline-flex items-center gap-1.5 text-sm font-semibold text-brand-teal">
              Visit site
              <span aria-hidden="true" class="transition-transform group-hover:translate-x-0.5">→</span>
            </span>
          </a>
        ))
      }
    </div>
  </div>
</section>
