---
// src/components/ContactForm.astro
import { site } from "../data/site";

interface Props {
  title?: string;
  showVillaSelect?: boolean;
  preselectVilla?: string;
}
const {
  title = "Send Us a Message",
  showVillaSelect = false,
  preselectVilla,
} = Astro.props;

const villas = [
  "Poolside Studio #9",
  "Poolside Studio #10",
  "Garden View Villa #3",
  "Ocean Front Villa #7",
  "Avenue View Villa #1",
  "Avenue View Villa #2",
  "Ocean View Villa #4",
  "Ocean Front Villa #6",
  "Ocean Front Villa #8",
  "Ocean View Penthouse #5",
];

const fieldClass =
  "w-full rounded-xl border border-brand-border bg-brand-sand/40 px-4 py-3 text-sm text-brand-navy placeholder:text-brand-muted/70 focus:outline-none focus:ring-2 focus:ring-brand-teal focus:border-brand-teal transition";
const labelClass = "block text-sm font-semibold text-brand-navy mb-1.5";
---

<div class="card p-8 md:p-10">
  <h2 class="font-display text-h2 mb-2">{title}</h2>
  <p class="text-sm text-brand-muted mb-7">
    Prefer to talk? Call us at
    <a href={site.phoneHref} class="text-brand-teal font-semibold hover:underline">{site.phone}</a>.
  </p>

  <form name="contact" method="POST" data-netlify="true" class="space-y-5">
    <input type="hidden" name="form-name" value="contact" />

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
      <div>
        <label for="name" class={labelClass}>Full Name *</label>
        <input id="name" name="name" type="text" required class={fieldClass} placeholder="Jane Smith" />
      </div>
      <div>
        <label for="email" class={labelClass}>Email *</label>
        <input id="email" name="email" type="email" required class={fieldClass} placeholder="jane@email.com" />
      </div>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
      <div>
        <label for="phone" class={labelClass}>Phone</label>
        <input id="phone" name="phone" type="tel" class={fieldClass} placeholder="(760) 555-0100" />
      </div>

      {
        showVillaSelect && (
          <div>
            <label for="villa" class={labelClass}>Villa of Interest</label>
            <select id="villa" name="villa" class={fieldClass}>
              <option value="">Select a villa…</option>
              {villas.map((v) => (
                <option value={v} selected={v === preselectVilla}>
                  {v}
                </option>
              ))}
            </select>
          </div>
        )
      }
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
      <div>
        <label for="checkin" class={labelClass}>Check-In Date</label>
        <input id="checkin" name="checkin" type="date" class={fieldClass} />
      </div>
      <div>
        <label for="checkout" class={labelClass}>Check-Out Date</label>
        <input id="checkout" name="checkout" type="date" class={fieldClass} />
      </div>
    </div>

    <div>
      <label for="message" class={labelClass}>Message</label>
      <textarea
        id="message"
        name="message"
        rows={5}
        class={`${fieldClass} resize-none`}
        placeholder="Tell us about your stay, questions, or special requests…"
      ></textarea>
    </div>

    {
      preselectVilla && !showVillaSelect && (
        <input type="hidden" name="villa" value={preselectVilla} />
      )
    }

    <button type="submit" class="btn btn-primary w-full sm:w-auto">Send Message</button>
  </form>
</div>
