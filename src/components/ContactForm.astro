---
// src/components/ContactForm.astro
import { site } from "../data/site";

interface Props {
  title?: string;
  showVillaSelect?: boolean;
  preselectVilla?: string;
}
const {
  title = "Send Us a Message",
  showVillaSelect = false,
  preselectVilla,
} = Astro.props;

// Web3Forms access key — static-site friendly form delivery.
// Set PUBLIC_WEB3FORMS_KEY in your env (see .env.example). When unset, the
// form gracefully falls back to opening the visitor's email client.
const formKey = import.meta.env.PUBLIC_WEB3FORMS_KEY ?? "";

const villas = [
  "Poolside Studio #9",
  "Poolside Studio #10",
  "Garden View Villa #3",
  "Ocean Front Villa #7",
  "Avenue View Villa #1",
  "Avenue View Villa #2",
  "Ocean View Villa #4",
  "Ocean Front Villa #6",
  "Ocean Front Villa #8",
  "Ocean View Penthouse #5",
];

const fieldClass =
  "w-full rounded-xl border border-brand-border bg-sand/40 px-4 py-3 text-sm text-navy placeholder:text-brand-muted/70 focus:outline-none focus:ring-2 focus:ring-seafoam focus:border-seafoam transition";
const labelClass = "block text-sm font-semibold text-navy mb-1.5";
---

<div class="card p-8 md:p-10">
  <h2 class="font-serif text-h2 mb-2">{title}</h2>
  <p class="text-sm text-brand-muted mb-7">
    Prefer to talk? Call us at
    <a href={site.phoneHref} class="text-seafoam font-semibold hover:underline">{site.phone}</a>.
  </p>

  <form
    id="contact-form"
    method="POST"
    action="https://api.web3forms.com/submit"
    class="space-y-5"
    data-form-key={formKey}
    data-fallback-email={site.email}
  >
    <!-- Web3Forms config -->
    <input type="hidden" name="access_key" value={formKey} />
    <input type="hidden" name="subject" value="New inquiry from the Beachwalk Villas website" />
    <input type="hidden" name="from_name" value="Beachwalk Villas Website" />
    <!-- Honeypot (hidden from real users) -->
    <input type="checkbox" name="botcheck" class="hidden" style="display:none" tabindex="-1" aria-hidden="true" />

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
      <div>
        <label for="name" class={labelClass}>Full Name *</label>
        <input id="name" name="name" type="text" required aria-required="true" class={fieldClass} placeholder="Jane Smith" />
      </div>
      <div>
        <label for="email" class={labelClass}>Email *</label>
        <input id="email" name="email" type="email" required aria-required="true" class={fieldClass} placeholder="jane@email.com" />
      </div>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
      <div>
        <label for="phone" class={labelClass}>Phone</label>
        <input id="phone" name="phone" type="tel" class={fieldClass} placeholder="(760) 555-0100" />
      </div>

      {
        showVillaSelect && (
          <div>
            <label for="villa" class={labelClass}>Villa of Interest</label>
            <select id="villa" name="villa" class={fieldClass}>
              <option value="">Select a villa…</option>
              {villas.map((v) => (
                <option value={v} selected={v === preselectVilla}>
                  {v}
                </option>
              ))}
            </select>
          </div>
        )
      }
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
      <div>
        <label for="checkin" class={labelClass}>Check-In Date</label>
        <input id="checkin" name="checkin" type="date" class={fieldClass} />
      </div>
      <div>
        <label for="checkout" class={labelClass}>Check-Out Date</label>
        <input id="checkout" name="checkout" type="date" class={fieldClass} />
      </div>
    </div>

    <div>
      <label for="message" class={labelClass}>Message</label>
      <textarea
        id="message"
        name="message"
        rows={5}
        class={`${fieldClass} resize-none`}
        placeholder="Tell us about your stay, questions, or special requests…"
      ></textarea>
    </div>

    {
      preselectVilla && !showVillaSelect && (
        <input type="hidden" name="villa" value={preselectVilla} />
      )
    }

    <div class="flex flex-col sm:flex-row sm:items-center gap-4">
      <button type="submit" class="btn btn-primary w-full sm:w-auto">Send Message</button>
      <p id="form-status" role="status" aria-live="polite" class="hidden text-sm font-medium"></p>
    </div>
  </form>
</div>

<script>
  const form = document.getElementById("contact-form") as HTMLFormElement | null;
  const statusEl = document.getElementById("form-status");

  if (form && statusEl) {
    const key = form.dataset.formKey || "";
    const fallbackEmail = form.dataset.fallbackEmail || "";
    const submitBtn = form.querySelector<HTMLButtonElement>('button[type="submit"]');

    const setStatus = (msg: string, kind: "ok" | "err" | "info") => {
      statusEl.textContent = msg;
      statusEl.classList.remove("hidden", "text-seafoam", "text-terracotta", "text-brand-muted");
      statusEl.classList.add(
        kind === "ok" ? "text-seafoam" : kind === "err" ? "text-terracotta" : "text-brand-muted",
      );
    };

    form.addEventListener("submit", async (e) => {
      e.preventDefault();
      const data = new FormData(form);

      // Honeypot — silently drop bot submissions
      if (data.get("botcheck")) return;

      // No form provider configured → fall back to the visitor's email client
      if (!key) {
        const lines: string[] = [];
        for (const [k, v] of data.entries()) {
          if (["access_key", "botcheck", "subject", "from_name"].includes(k)) continue;
          if (typeof v === "string" && v.trim()) lines.push(`${k}: ${v}`);
        }
        const subject = encodeURIComponent("Beachwalk Villas inquiry");
        const body = encodeURIComponent(lines.join("\n"));
        window.location.href = `mailto:${fallbackEmail}?subject=${subject}&body=${body}`;
        setStatus("Opening your email app…", "info");
        return;
      }

      submitBtn?.setAttribute("disabled", "true");
      setStatus("Sending…", "info");

      try {
        const res = await fetch("https://api.web3forms.com/submit", {
          method: "POST",
          headers: { Accept: "application/json" },
          body: data,
        });
        const json = await res.json();
        if (res.ok && json.success) {
          form.reset();
          setStatus("Thanks! Your message has been sent — we'll be in touch shortly.", "ok");
        } else {
          setStatus("Something went wrong. Please call us or email directly.", "err");
        }
      } catch {
        setStatus("Network error. Please call us or email directly.", "err");
      } finally {
        submitBtn?.removeAttribute("disabled");
      }
    });
  }
</script>
