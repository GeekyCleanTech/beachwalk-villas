---
// src/components/ContactForm.astro
interface Props {
  title?: string;
  showVillaSelect?: boolean;
}
const { title = 'Contact Us', showVillaSelect = false } = Astro.props;

const villas = [
  'Avenue View Villa #1',
  'Avenue View Villa #2',
  'Garden View Villa #3',
  'Ocean View Villa #4',
  'Ocean View Villa #5',
  'Ocean Front Villa #6',
  'Ocean Front Villa #7',
  'Ocean Front Villa #8',
  'Poolside Studio #9',
  'Poolside Studio #10',
];
---

<div class="bg-white shadow-sm border border-gray-100 p-8 md:p-10">
  <h2 class="font-display text-h2 text-brand-navy mb-6">{title}</h2>

  <!-- Cloudflare Forms or replace with your preferred form handler -->
  <form
    name="contact"
    method="POST"
    data-netlify="true"
    class="space-y-5"
  >
    <input type="hidden" name="form-name" value="contact" />

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
      <div>
        <label for="name" class="block text-sm font-semibold text-gray-700 mb-1.5">Full Name *</label>
        <input
          id="name"
          name="name"
          type="text"
          required
          class="w-full border border-gray-200 px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-brand-teal"
          placeholder="Jane Smith"
        />
      </div>
      <div>
        <label for="email" class="block text-sm font-semibold text-gray-700 mb-1.5">Email *</label>
        <input
          id="email"
          name="email"
          type="email"
          required
          class="w-full border border-gray-200 px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-brand-teal"
          placeholder="jane@email.com"
        />
      </div>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
      <div>
        <label for="phone" class="block text-sm font-semibold text-gray-700 mb-1.5">Phone</label>
        <input
          id="phone"
          name="phone"
          type="tel"
          class="w-full border border-gray-200 px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-brand-teal"
          placeholder="(760) 555-0100"
        />
      </div>

      {showVillaSelect && (
        <div>
          <label for="villa" class="block text-sm font-semibold text-gray-700 mb-1.5">Villa of Interest</label>
          <select
            id="villa"
            name="villa"
            class="w-full border border-gray-200 px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-brand-teal bg-white"
          >
            <option value="">Select a villa...</option>
            {villas.map(v => <option value={v}>{v}</option>)}
          </select>
        </div>
      )}
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
      <div>
        <label for="checkin" class="block text-sm font-semibold text-gray-700 mb-1.5">Check-In Date</label>
        <input
          id="checkin"
          name="checkin"
          type="date"
          class="w-full border border-gray-200 px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-brand-teal"
        />
      </div>
      <div>
        <label for="checkout" class="block text-sm font-semibold text-gray-700 mb-1.5">Check-Out Date</label>
        <input
          id="checkout"
          name="checkout"
          type="date"
          class="w-full border border-gray-200 px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-brand-teal"
        />
      </div>
    </div>

    <div>
      <label for="message" class="block text-sm font-semibold text-gray-700 mb-1.5">Message</label>
      <textarea
        id="message"
        name="message"
        rows={5}
        class="w-full border border-gray-200 px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-brand-teal resize-none"
        placeholder="Tell us about your stay, questions, or special requests..."
      ></textarea>
    </div>

    <button type="submit" class="btn-primary w-full sm:w-auto">
      Send Message
    </button>
  </form>
</div>
