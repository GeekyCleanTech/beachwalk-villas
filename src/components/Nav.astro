---
// src/components/Nav.astro
import { navLinks, site } from "../data/site";
const pathname = Astro.url.pathname;
const isActive = (href: string) =>
  href === "/" ? pathname === "/" : pathname.startsWith(href);
---

<nav
  id="main-nav"
  class="w-full bg-sand/95 text-navy sticky top-0 z-50 border-b border-brand-border transition-all duration-300"
>
  <div class="container-site flex items-center justify-between h-16 md:h-20">
    <!-- Logo -->
    <a href="/" class="flex-shrink-0 flex items-center gap-3" aria-label="Beachwalk Villas — home">
      <img
        src="/images/logo.png"
        alt="Beachwalk Villas"
        class="h-9 md:h-11 w-auto"
        style="filter: brightness(0) saturate(100%) invert(16%) sepia(37%) saturate(3941%) hue-rotate(176deg) brightness(93%) contrast(95%);"
        loading="eager"
      />
    </a>

    <!-- Desktop nav links -->
    <ul class="hidden lg:flex items-center gap-7 xl:gap-9">
      {
        navLinks.map((link) => (
          <li>
            <a
              href={link.href}
              class={`text-sm font-medium tracking-wide transition-colors duration-150 ${
                isActive(link.href)
                  ? "text-seafoam"
                  : "text-navy/80 hover:text-seafoam"
              }`}
            >
              {link.label}
            </a>
          </li>
        ))
      }
      <li>
        <a
          href="/#other-properties"
          class="text-sm font-medium tracking-wide text-navy/80 hover:text-seafoam transition-colors"
        >
          Other Properties
        </a>
      </li>
    </ul>

    <!-- Right: phone + Book Now -->
    <div class="hidden lg:flex items-center gap-5">
      <a
        href={site.phoneHref}
        class="text-sm font-semibold text-navy hover:text-seafoam transition-colors whitespace-nowrap"
      >
        {site.phone}
      </a>
      <a href="/contact-us/" class="btn btn-coral !py-2.5 !px-6 text-sm">Book Now</a>
    </div>

    <!-- Mobile hamburger -->
    <button
      id="mobile-menu-btn"
      class="lg:hidden flex flex-col gap-1.5 p-2"
      aria-label="Open navigation menu"
      aria-expanded="false"
    >
      <span class="block w-6 h-0.5 bg-navy transition-all"></span>
      <span class="block w-6 h-0.5 bg-navy transition-all"></span>
      <span class="block w-6 h-0.5 bg-navy transition-all"></span>
    </button>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden lg:hidden bg-sand border-t border-brand-border">
    <ul class="container-site py-4 flex flex-col gap-1">
      {
        navLinks.map((link) => (
          <li>
            <a
              href={link.href}
              class={`block py-2.5 text-sm font-medium tracking-wide ${
                isActive(link.href) ? "text-seafoam" : "text-navy/80"
              }`}
            >
              {link.label}
            </a>
          </li>
        ))
      }
      <li>
        <a href="/#other-properties" class="block py-2.5 text-sm font-medium text-navy/80">
          Other Properties
        </a>
      </li>
      <li class="pt-3 mt-2 border-t border-brand-border flex flex-col gap-3">
        <a href={site.phoneHref} class="text-sm font-semibold text-navy">
          {site.phone}
        </a>
        <a href="/contact-us/" class="btn btn-coral text-sm w-full">Book Now</a>
      </li>
    </ul>
  </div>
</nav>

<script>
  const btn = document.getElementById("mobile-menu-btn");
  const menu = document.getElementById("mobile-menu");
  btn?.addEventListener("click", () => {
    const isOpen = menu?.classList.toggle("hidden") === false;
    btn.setAttribute("aria-expanded", String(isOpen));
  });

  // Subtle nav style change on scroll
  const nav = document.getElementById("main-nav");
  if (nav) {
    let ticking = false;
    const update = () => {
      nav.classList.toggle("nav-scrolled", window.scrollY > 40);
      ticking = false;
    };
    window.addEventListener(
      "scroll",
      () => {
        if (!ticking) {
          requestAnimationFrame(update);
          ticking = true;
        }
      },
      { passive: true },
    );
  }
</script>
