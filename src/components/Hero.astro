---
// src/components/Hero.astro
import { Image } from "astro:assets";

interface Props {
  eyebrow?: string;
  headline: string;
  subheadline?: string;
  ctaLabel?: string;
  ctaHref?: string;
  ctaSecondaryLabel?: string;
  ctaSecondaryHref?: string;
  bgVideo?: string;
  bgImage?: string | ImageMetadata;
  align?: "center" | "left";
  size?: "full" | "large" | "medium";
}

const {
  eyebrow,
  headline,
  subheadline,
  ctaLabel,
  ctaHref = "/villas/",
  ctaSecondaryLabel,
  ctaSecondaryHref,
  bgVideo,
  bgImage = "/images/beachwalk-featured-images.jpg",
  align = "center",
  size = "full",
} = Astro.props;

const sizeClasses = {
  full: "min-h-[88vh]",
  large: "min-h-[62vh]",
  medium: "min-h-[44vh]",
};

const alignClasses =
  align === "center"
    ? "items-center text-center"
    : "items-center text-left";
const contentAlign = align === "center" ? "mx-auto" : "mr-auto";

const isImageMetadata = (img: any): img is ImageMetadata => img && typeof img.src === 'string' && typeof img.width === 'number';
---

<section
  class={`relative flex ${alignClasses} ${sizeClasses[size]} overflow-hidden`}
>
  <!-- Background -->
  {
    bgVideo ? (
      <video
        id="hero-bg"
        class="absolute inset-0 w-full h-full object-cover will-change-transform"
        autoplay
        muted
        loop
        playsinline
        poster={typeof bgImage === 'string' ? bgImage : bgImage?.src}
      >
        <source src={bgVideo} type="video/mp4" />
      </video>
    ) : isImageMetadata(bgImage) ? (
      <Image
        id="hero-bg"
        src={bgImage}
        alt=""
        class="absolute inset-0 w-full h-full object-cover will-change-transform"
        loading="eager"
        decoding="async"
        fetchpriority="high"
      />
    ) : (
      <img
        id="hero-bg"
        src={bgImage}
        alt="Hero background"
        class="absolute inset-0 w-full h-full object-cover will-change-transform"
        loading="eager"
        decoding="async"
        fetchpriority="high"
      />
    )
  }

  <!-- Gradient scrim (always, for legibility over imagery) -->
  <div class="absolute inset-0 scrim"></div>

  <!-- Content -->
  <div class={`relative z-10 container-site text-white py-24 ${align === "center" ? "" : ""}`}>
    <div class={`max-w-3xl ${contentAlign}`}>
      {
        eyebrow && (
          <p class="hero-animate-headline font-body font-semibold tracking-[0.18em] uppercase text-sm text-white/85 mb-4">
            {eyebrow}
          </p>
        )
      }
      <h1
        class="font-display text-hero text-balance mb-5 drop-shadow-md hero-animate-headline"
      >
        {headline}
      </h1>

      {
        subheadline && (
          <p
            class={`font-body text-lg md:text-xl text-white/90 mb-9 text-balance hero-animate-subheadline ${
              align === "center" ? "max-w-2xl mx-auto" : "max-w-xl"
            }`}
          >
            {subheadline}
          </p>
        )
      }

      {
        (ctaLabel || ctaSecondaryLabel) && (
          <div
            class={`flex flex-col sm:flex-row gap-4 hero-animate-cta ${
              align === "center" ? "justify-center" : "justify-start"
            }`}
          >
            {ctaLabel && (
              <a href={ctaHref} class="btn btn-coral">
                {ctaLabel}
              </a>
            )}
            {ctaSecondaryLabel && ctaSecondaryHref && (
              <a href={ctaSecondaryHref} class="btn btn-white">
                {ctaSecondaryLabel}
              </a>
            )}
          </div>
        )
      }
    </div>
  </div>
</section>

<script>
  // Gentle parallax on the hero background
  const heroBg = document.getElementById("hero-bg");
  const prefersReducedMotion = window.matchMedia(
    "(prefers-reduced-motion: reduce)",
  ).matches;

  if (heroBg && !prefersReducedMotion) {
    let ticking = false;
    const update = () => {
      heroBg.style.transform = `translateY(${window.scrollY * 0.35}px)`;
      ticking = false;
    };
    window.addEventListener(
      "scroll",
      () => {
        if (!ticking) {
          requestAnimationFrame(update);
          ticking = true;
        }
      },
      { passive: true },
    );
  }
</script>
