---
// src/components/VillaCard.astro
import { typeLabels, typeBadge } from "../data/site";

interface Props {
  title: string;
  slug: string;
  type: string;
  thumbnailImage: string;
  bedrooms: number;
  bathrooms: number;
  maxGuests?: number;
  sqft?: number;
  tagline?: string;
  eager?: boolean;
}

const {
  title,
  slug,
  type,
  thumbnailImage,
  bedrooms,
  bathrooms,
  maxGuests,
  sqft,
  tagline,
  eager = false,
} = Astro.props;

const typeLabel = typeLabels[type] ?? type;
const badgeStyle = typeBadge[type];
const bedroomChip = bedrooms === 0 ? "Studio" : `${bedrooms} bed`;

// Small inline icons for the chips
const chips: { label: string }[] = [
  { label: bedroomChip },
  { label: `${bathrooms} bath` },
];
if (maxGuests) chips.push({ label: `${maxGuests} guests` });
if (sqft) chips.push({ label: `${sqft.toLocaleString()} sq ft` });
---

<article class="villa-card-reveal card group flex flex-col h-full transition-shadow duration-300 hover:shadow-[var(--shadow-lift)]">
  <!-- Large photo -->
  <a
    href={`/villas/${slug}/`}
    class="relative block overflow-hidden aspect-[4/3]"
    aria-label={`View ${title}`}
  >
    <img
      src={thumbnailImage}
      alt={title}
      class="w-full h-full object-cover transition-transform duration-700 ease-out group-hover:scale-105"
      loading={eager ? "eager" : "lazy"}
    />
    {
      badgeStyle && (
        <span
          class={`badge absolute top-4 left-4 ${badgeStyle === "ocean" ? "badge-ocean" : "badge-coral"}`}
        >
          {typeLabel}
        </span>
      )
    }
  </a>

  <!-- Content -->
  <div class="flex flex-col flex-1 p-6">
    <span class="eyebrow mb-2">{typeLabel}</span>
    <h3 class="font-display text-h3 leading-tight mb-2">
      <a
        href={`/villas/${slug}/`}
        class="transition-colors hover:text-brand-teal"
      >
        {title}
      </a>
    </h3>

    {
      tagline && (
        <p class="text-sm text-brand-muted leading-relaxed mb-4">{tagline}</p>
      )
    }

    <!-- Pill chips: beds · baths · guests · sq ft -->
    <div class="mt-auto flex flex-wrap gap-2 pt-2">
      {chips.map((c) => <span class="chip">{c.label}</span>)}
    </div>

    <a
      href={`/villas/${slug}/`}
      class="mt-5 inline-flex items-center gap-1.5 text-sm font-semibold text-brand-teal hover:text-brand-teal-dark transition-colors"
    >
      View villa
      <span aria-hidden="true" class="transition-transform group-hover:translate-x-0.5">→</span>
    </a>
  </div>
</article>
