---
// src/components/VillaCard.astro
interface Props {
  title: string;
  slug: string;
  type: string;
  thumbnailImage: string;
  bedrooms: number;
  bathrooms: number;
  unitAmenities?: string[];
  nightlyRate?: number;
}

const {
  title,
  slug,
  type,
  thumbnailImage,
  bedrooms,
  bathrooms,
  unitAmenities = [],
  nightlyRate,
} = Astro.props;

const typeLabels: Record<string, string> = {
  "ocean-front": "Ocean Front",
  "ocean-view": "Ocean View",
  "avenue-view": "Avenue View",
  "garden-view": "Garden View",
  "poolside-studio": "Poolside Studio",
};

const typeLabel = typeLabels[type] ?? type;
const bedroomLabel = bedrooms === 0 ? "Studio" : `${bedrooms} BR`;
---

<article
  class="villa-card-reveal group bg-white border border-gray-100 shadow-sm hover:shadow-md transition-shadow duration-200 overflow-hidden"
>
  <!-- Image -->
  <a href={`/villas/${slug}/`} class="block overflow-hidden aspect-[3/2]">
    <img
      src={thumbnailImage}
      alt={title}
      class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500 ease-out"
      loading="lazy"
    />
  </a>

  <!-- Content -->
  <div class="p-5">
    <!-- Type badge -->
    <span
      class="inline-block text-xs font-body font-semibold uppercase tracking-widest text-brand-teal mb-2"
    >
      {typeLabel}
    </span>

    <!-- Title -->
    <h3 class="font-display text-h3 text-brand-navy mb-3">
      <a
        href={`/villas/${slug}/`}
        class="hover:text-brand-teal transition-colors"
      >
        {title}
      </a>
    </h3>

    <!-- Details row -->
    <div class="flex items-center gap-4 text-sm text-gray-500 mb-4">
      <span>{bedroomLabel}</span>
      <span class="w-1 h-1 rounded-full bg-gray-300"></span>
      <span>{bathrooms} Bath</span>
      {
        nightlyRate && (
          <>
            <span class="w-1 h-1 rounded-full bg-gray-300" />
            <span class="text-brand-teal font-semibold">
              From ${nightlyRate}/night
            </span>
          </>
        )
      }
    </div>

    <!-- Amenity pills (first 3) -->
    {
      unitAmenities.length > 0 && (
        <div class="flex flex-wrap gap-1.5 mb-5">
          {unitAmenities.slice(0, 3).map((a) => (
            <span class="text-xs bg-brand-sand text-brand-navy px-2.5 py-1 rounded-full font-body">
              {a}
            </span>
          ))}
        </div>
      )
    }

    <a href={`/villas/${slug}/`} class="btn-outline text-sm px-5 py-2">
      View Villa
    </a>
  </div>
</article>
